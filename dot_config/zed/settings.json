// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  // --- テーマ ---
  "theme": {
    "mode": "dark",
    "light": "One Light",
    "dark": "Tokyo Night Storm"
  },
  "icon_theme": "Zed (Default)",

  // --- フォント ---
  "ui_font_size": 16,
  "buffer_font_family": "Zed Mono",
  "buffer_font_size": 15,

  // --- エディタ基本 ---
  "base_keymap": "VSCode",
  "tab_size": 4,
  "soft_wrap": "editor_width",
  "show_whitespaces": "selection",
  "autosave": "on_focus_change",
  "format_on_save": "on",
  "indent_guides": {
    "enabled": true
  },

  // --- パネル配置 ---
  "project_panel": {
    "dock": "left",
    "file_icons": true,
    "git_status": true
  },
  "outline_panel": {
    "dock": "left"
  },
  "collaboration_panel": {
    "dock": "left"
  },
  "git_panel": {
    "dock": "left"
  },

  // --- Git ---
  "git": {
    "inline_blame": {
      "enabled": true
    }
  },

  // --- AI / Agent ---
  "edit_predictions": {
    "provider": "copilot"
  },
  "agent": {
    "dock": "right",
    "sidebar_side": "right",
    "favorite_models": [],
    "model_parameters": []
  },
  "agent_servers": {
    "cursor": {
      "default_config_options": {
        "model": "composer-2.5[fast=true]"
      },
      "type": "registry"
    },
    "claude-acp": {
      "default_config_options": {
        "model": "default",
        "mode": "bypassPermissions",
        "effort": "high"
      },
      "favorite_config_option_values": {
        "mode": [
          "bypassPermissions"
        ],
        "effort": [
          "high"
        ]
      },
      "type": "registry"
    }
  },

  // --- セッション ---
  "session": {
    "trust_all_worktrees": true
  },

  // --- パフォーマンス（重いディレクトリを除外） ---
  "file_scan_exclusions": [
    "**/.git",
    "**/node_modules",
    "**/.venv",
    "**/__pycache__",
    "**/.mypy_cache",
    "**/.ruff_cache"
  ],

  // --- 言語別設定 ---
  "languages": {
    "Python": {
      "language_servers": ["basedpyright", "ruff"],
      "format_on_save": "on",
      "formatter": {
        "language_server": { "name": "ruff" }
      },
      "tab_size": 4
    },
    "HTML": {
      "format_on_save": "on",
      "tab_size": 2
    },
    "CSS": {
      "format_on_save": "on",
      "tab_size": 2
    },
    "JavaScript": {
      "format_on_save": "on",
      "tab_size": 2
    },
    "TypeScript": {
      "format_on_save": "on",
      "tab_size": 2
    },
    "JSON": {
      "format_on_save": "on",
      "tab_size": 2
    }
  }
}
